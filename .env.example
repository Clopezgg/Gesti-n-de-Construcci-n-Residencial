# ConstruControl - Oracle Cloud + Coolify / Docker Compose
# Copy only for local testing. In Coolify, create these values in Environment Variables.

ERPNEXT_VERSION=v15.117.0
SITE_NAME=construcontrol
DB_NAME=_construcontrol
DB_PASSWORD=replace-with-a-long-random-database-password
DB_ROOT_PASSWORD=replace-with-a-different-long-root-password
ADMIN_PASSWORD=replace-with-a-long-initial-administrator-password
FRAPPE_ENCRYPTION_KEY=replace-with-output-of-openssl-rand-base64-32
FRAPPE_EXTERNAL_URL=
TZ=America/Tegucigalpa

# Runtime tuning for the Oracle Always Free Ampere VM.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# Persistent local backup settings.
BACKUP_LOCAL_HOUR=2
BACKUP_RETENTION_DAYS=14
BACKUP_RUN_ON_START=true

# Optional Supabase server-only integration.
# Leave blank when using only the persistent Oracle volume.
SUPABASE_URL=
SUPABASE_SERVER_KEY=
SUPABASE_STORAGE_MODE=disabled
SUPABASE_STORAGE_BUCKET=construction-evidence
SUPABASE_MIGRATION_BUCKET=construcontrol-migration
SUPABASE_BACKUP_BUCKET=construcontrol-backups
SUPABASE_PROJECT_ID=

# Local source export paths.
CONSTRUCONTROL_SOURCE_PROJECT_ID=
CONSTRUCONTROL_EXPORT_DIR=./migration-output/source-export
CONSTRUCONTROL_EVIDENCE_MAX_BYTES=12582912
