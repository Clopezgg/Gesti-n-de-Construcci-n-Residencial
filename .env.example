# ConstruControl - AWS EC2 + Coolify + Docker Compose
# Plantilla sin secretos. Configure valores reales en Coolify > Environment Variables.

ERPNEXT_VERSION=v15.117.0
SITE_NAME=construcontrol
DB_NAME=_construcontrol
DB_PASSWORD=REEMPLAZAR_CON_CONTRASENA_LARGA_Y_UNICA
DB_ROOT_PASSWORD=REEMPLAZAR_CON_OTRA_CONTRASENA_LARGA_Y_UNICA
ADMIN_PASSWORD=REEMPLAZAR_CON_CONTRASENA_INICIAL_DE_ADMINISTRATOR
FRAPPE_ENCRYPTION_KEY=REEMPLAZAR_CON_SALIDA_DE_OPENSSL_RAND_BASE64_32
FRAPPE_EXTERNAL_URL=https://app.ejemplo.com
TZ=America/Tegucigalpa

# Ajuste para una instancia EC2 x86_64 con aproximadamente 8 GiB de RAM.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# Respaldos productivos: exclusivamente en el volumen persistente sites de AWS/Coolify.
BACKUP_LOCAL_HOUR=2
BACKUP_RETENTION_DAYS=14
BACKUP_RUN_ON_START=false

# Supabase es solo origen histórico de migración. No es base productiva ni destino de backup.
# Variables exclusivamente de servidor; nunca use anon, publishable o VITE_.
SUPABASE_URL=
SUPABASE_SERVER_KEY=
SUPABASE_STORAGE_MODE=disabled
SUPABASE_STORAGE_BUCKET=construction-evidence
SUPABASE_MIGRATION_BUCKET=construcontrol-migration
SUPABASE_PROJECT_ID=

CONSTRUCONTROL_SOURCE_PROJECT_ID=
CONSTRUCONTROL_EXPORT_DIR=./migration-output/source-export
CONSTRUCONTROL_EVIDENCE_MAX_BYTES=12582912
