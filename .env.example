# Frappe / ERPNext
SITE_NAME=construcontrol.localhost
FRAPPE_SITE_NAME_HEADER=construcontrol.localhost
FRAPPE_EXTERNAL_URL=http://localhost:8080
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=_construcontrol
DB_PASSWORD=replace-with-a-random-database-password
DB_ROOT_USER=root
DB_ROOT_PASSWORD=replace-with-the-mariadb-root-password
REDIS_CACHE=redis://redis-cache:6379
REDIS_QUEUE=redis://redis-queue:6379
ADMIN_PASSWORD=replace-with-the-initial-administrator-password
FRAPPE_ENCRYPTION_KEY=replace-with-a-persistent-random-32-byte-key
SOCKETIO_PORT=9000
PORT=8080

# Supabase server-only access. Prefer an sb_secret_ key.
# A legacy service_role JWT is accepted temporarily for backwards compatibility.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_SERVER_KEY=replace-with-a-server-secret-key
SUPABASE_STORAGE_MODE=disabled
SUPABASE_STORAGE_BUCKET=construction-evidence
SUPABASE_MIGRATION_BUCKET=construcontrol-migration
SUPABASE_BACKUP_BUCKET=construcontrol-backups

# Source export input/output
CONSTRUCONTROL_SOURCE_PROJECT_ID=
CONSTRUCONTROL_EXPORT_DIR=./migration-output/source-export
CONSTRUCONTROL_EVIDENCE_MAX_BYTES=12582912
