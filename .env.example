# ConstruControl - AWS EC2 + Coolify + Docker Compose
# Plantilla sin secretos. En producción configure estos valores en Coolify > Environment Variables.

ERPNEXT_VERSION=v15.117.0
SITE_NAME=construcontrol
DB_NAME=_construcontrol
DB_PASSWORD=REEMPLAZAR_CON_CONTRASENA_LARGA_Y_UNICA
DB_ROOT_PASSWORD=REEMPLAZAR_CON_OTRA_CONTRASENA_LARGA_Y_UNICA
ADMIN_PASSWORD=REEMPLAZAR_CON_CONTRASENA_INICIAL_DE_ADMINISTRATOR
FRAPPE_ENCRYPTION_KEY=REEMPLAZAR_CON_SALIDA_DE_OPENSSL_RAND_BASE64_32
FRAPPE_EXTERNAL_URL=https://app.ejemplo.com
TZ=America/Tegucigalpa

# Ajuste actual para una instancia EC2 x86_64 con aproximadamente 8 GiB de RAM.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# Respaldos locales persistentes dentro del volumen sites.
# No se ejecuta al iniciar para evitar retrasos o ciclos durante un redeploy.
BACKUP_LOCAL_HOUR=2
BACKUP_RETENTION_DAYS=14
BACKUP_RUN_ON_START=false

# Supabase es opcional y solo servidor.
# En la arquitectura actual se usa para leer el origen histórico o guardar una copia remota privada.
# No use anon, publishable, VITE_ ni una clave expuesta al navegador.
SUPABASE_URL=
SUPABASE_SERVER_KEY=
SUPABASE_STORAGE_MODE=disabled
SUPABASE_STORAGE_BUCKET=construction-evidence
SUPABASE_MIGRATION_BUCKET=construcontrol-migration
SUPABASE_BACKUP_BUCKET=construcontrol-backups
SUPABASE_PROJECT_ID=

# Exportación local controlada del sistema anterior.
CONSTRUCONTROL_SOURCE_PROJECT_ID=
CONSTRUCONTROL_EXPORT_DIR=./migration-output/source-export
CONSTRUCONTROL_EVIDENCE_MAX_BYTES=12582912
